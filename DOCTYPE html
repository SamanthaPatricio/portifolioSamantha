<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Samantha Patrício | Analista de RH & DP</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C97A;
  --gold-pale: #F7EDD6;
  --dark: #1A1612;
  --dark-2: #2C2620;
  --dark-3: #3D3530;
  --mid: #6B5F56;
  --light: #F5F0E8;
  --white: #FDFAF4;
  --accent: #8B4513;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--dark);
  color: var(--white);
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.2rem 4rem;
  background: rgba(26,22,18,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(201,168,76,0.2);
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem; font-weight: 300; letter-spacing: 0.15em;
  color: var(--gold);
}
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a {
  font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(253,250,244,0.6);
  text-decoration: none; transition: color 0.3s;
}
.nav-links a:hover { color: var(--gold); }

/* HERO */
.hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 6rem 4rem 4rem;
  position: relative; overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; top: 0; right: 0;
  width: 50%; height: 100%;
  background: linear-gradient(135deg, var(--dark-2) 0%, var(--dark-3) 100%);
  clip-path: polygon(8% 0%, 100% 0%, 100% 100%, 0% 100%);
}
.hero-text { position: relative; z-index: 2; }
.hero-eyebrow {
  font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 1rem;
}
.hero-eyebrow::before {
  content: ''; width: 2.5rem; height: 1px; background: var(--gold);
}
.hero-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 5vw, 5rem);
  font-weight: 300; line-height: 1.05;
  margin-bottom: 0.5rem;
}
.hero-name span { font-style: italic; color: var(--gold-light); }
.hero-title {
  font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase;
  color: rgba(253,250,244,0.5); margin-bottom: 2.5rem;
}
.hero-desc {
  font-size: 1rem; line-height: 1.8;
  color: rgba(253,250,244,0.75);
  max-width: 480px; margin-bottom: 3rem;
}
.hero-cta {
  display: flex; gap: 1rem; flex-wrap: wrap;
}
.btn-primary {
  padding: 0.9rem 2rem;
  background: var(--gold); color: var(--dark);
  font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
  border: none; cursor: pointer; text-decoration: none;
  font-weight: 500; transition: all 0.3s;
}
.btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
.btn-outline {
  padding: 0.9rem 2rem;
  background: transparent; color: var(--gold);
  font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
  border: 1px solid rgba(201,168,76,0.4); cursor: pointer; text-decoration: none;
  font-weight: 400; transition: all 0.3s;
}
.btn-outline:hover { border-color: var(--gold); background: rgba(201,168,76,0.08); }

.hero-image {
  position: relative; z-index: 2;
  display: flex; justify-content: center; align-items: center;
}
.hero-photo-frame {
  position: relative; width: 380px; height: 460px;
}
.hero-photo-frame::before {
  content: '';
  position: absolute; top: -1.5rem; right: -1.5rem;
  width: 100%; height: 100%;
  border: 1px solid rgba(201,168,76,0.35);
}
.hero-photo-frame img {
  width: 100%; height: 100%; object-fit: cover; object-position: top;
  filter: sepia(10%) contrast(1.05);
}
.hero-stats {
  position: absolute; bottom: -1.5rem; left: -1.5rem;
  background: var(--dark); border: 1px solid rgba(201,168,76,0.3);
  padding: 1.2rem 1.8rem;
  display: flex; gap: 2rem;
}
.stat { text-align: center; }
.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem; font-weight: 600; color: var(--gold);
  display: block;
}
.stat-label {
  font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(253,250,244,0.45);
}

/* ABOUT / VAGA SECTION */
.vaga-section {
  padding: 6rem 4rem;
  background: var(--dark-2);
  position: relative;
}
.vaga-section::before {
  content: '';
  position: absolute; top: 0; left: 4rem; right: 4rem; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.section-label {
  font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 1rem;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300;
  line-height: 1.2; margin-bottom: 3rem;
}

.fit-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.fit-card {
  padding: 1.8rem;
  border: 1px solid rgba(201,168,76,0.15);
  background: rgba(201,168,76,0.04);
  position: relative; overflow: hidden;
  transition: all 0.3s;
}
.fit-card:hover {
  border-color: rgba(201,168,76,0.4);
  background: rgba(201,168,76,0.08);
}
.fit-card::before {
  content: attr(data-icon);
  position: absolute; right: 1.5rem; top: 1rem;
  font-size: 2rem; opacity: 0.1;
}
.fit-card-req {
  font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.5rem;
}
.fit-card-title {
  font-size: 0.95rem; font-weight: 500;
  margin-bottom: 0.8rem; line-height: 1.4;
}
.fit-card-answer {
  font-size: 0.85rem; line-height: 1.7;
  color: rgba(253,250,244,0.65);
}
.fit-check {
  display: inline-flex; align-items: center; gap: 0.4rem;
  margin-top: 0.8rem; font-size: 0.78rem; color: var(--gold);
}
.fit-check::before { content: '✓'; font-weight: 700; }

/* COMPETÊNCIAS */
.skills-section {
  padding: 6rem 4rem;
  background: var(--dark);
}
.skills-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.skill-block {
  padding: 2.5rem;
  border: 1px solid rgba(201,168,76,0.1);
  transition: background 0.3s;
}
.skill-block:hover { background: rgba(201,168,76,0.04); }
.skill-icon {
  width: 2.5rem; height: 2.5rem;
  border: 1px solid rgba(201,168,76,0.4);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.2rem;
  font-size: 1rem;
}
.skill-block-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem; font-weight: 400; margin-bottom: 1rem;
  color: var(--gold-light);
}
.skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tag {
  font-size: 0.72rem; letter-spacing: 0.08em;
  padding: 0.3rem 0.7rem;
  border: 1px solid rgba(201,168,76,0.25);
  color: rgba(253,250,244,0.6);
}
.tag.highlight {
  border-color: var(--gold);
  color: var(--gold);
}

/* EXPERIÊNCIA */
.exp-section {
  padding: 6rem 4rem;
  background: var(--dark-2);
}
.timeline { position: relative; }
.timeline::before {
  content: '';
  position: absolute; left: 11rem; top: 0; bottom: 0;
  width: 1px; background: rgba(201,168,76,0.2);
}
.exp-item {
  display: grid; grid-template-columns: 11rem 1fr;
  gap: 3rem; margin-bottom: 3.5rem;
  position: relative;
}
.exp-item::after {
  content: '';
  position: absolute; left: 11rem; top: 0.5rem;
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--gold); transform: translateX(-50%);
}
.exp-date {
  text-align: right;
  font-size: 0.78rem; letter-spacing: 0.1em;
  color: var(--gold); padding-top: 0.2rem;
}
.exp-current {
  font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(201,168,76,0.6); display: block; margin-top: 0.3rem;
}
.exp-content { padding-left: 2rem; }
.exp-company {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem; font-weight: 400; color: var(--gold-light);
  margin-bottom: 0.2rem;
}
.exp-role {
  font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(253,250,244,0.45); margin-bottom: 1rem;
}
.exp-desc {
  font-size: 0.88rem; line-height: 1.8;
  color: rgba(253,250,244,0.7);
}
.exp-highlights {
  margin-top: 0.8rem; display: flex; flex-wrap: wrap; gap: 0.4rem;
}
.exp-highlight {
  font-size: 0.72rem; padding: 0.25rem 0.7rem;
  background: rgba(201,168,76,0.1); color: var(--gold);
  letter-spacing: 0.05em;
}

/* CURSOS / CERTIFICAÇÕES */
.certs-section {
  padding: 6rem 4rem;
  background: var(--dark);
}
.certs-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1rem; margin-top: 1rem;
}
.cert-card {
  padding: 1.4rem 1.6rem;
  border: 1px solid rgba(201,168,76,0.12);
  background: rgba(201,168,76,0.03);
  position: relative; overflow: hidden; transition: all 0.3s;
}
.cert-card:hover {
  border-color: rgba(201,168,76,0.35);
  background: rgba(201,168,76,0.07);
  transform: translateY(-3px);
}
.cert-inst {
  font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 0.5rem;
}
.cert-name {
  font-size: 0.85rem; line-height: 1.4; font-weight: 400;
  color: rgba(253,250,244,0.85);
}
.cert-year {
  font-size: 0.72rem; color: rgba(253,250,244,0.35);
  margin-top: 0.6rem; letter-spacing: 0.08em;
}
.cert-badge {
  position: absolute; top: 0.8rem; right: 0.8rem;
  font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0.2rem 0.5rem;
  background: rgba(201,168,76,0.15); color: var(--gold);
}

/* DIFERENCIAL */
.diff-section {
  padding: 6rem 4rem;
  background: linear-gradient(135deg, var(--dark-2) 0%, var(--dark-3) 100%);
  position: relative; overflow: hidden;
}
.diff-section::after {
  content: 'SAMANTHA';
  position: absolute; right: -2rem; top: 50%;
  transform: translateY(-50%) rotate(90deg);
  font-family: 'Cormorant Garamond', serif;
  font-size: 8rem; font-weight: 600; letter-spacing: 0.3em;
  color: rgba(201,168,76,0.05);
  white-space: nowrap; pointer-events: none;
}
.diff-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
  margin-top: 2rem;
}
.diff-item {
  display: flex; gap: 1.5rem; align-items: flex-start;
}
.diff-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3rem; font-weight: 300; color: rgba(201,168,76,0.25);
  line-height: 1; flex-shrink: 0; width: 3rem;
}
.diff-content {}
.diff-title {
  font-size: 1rem; font-weight: 500; margin-bottom: 0.5rem;
  color: var(--gold-light);
}
.diff-text {
  font-size: 0.85rem; line-height: 1.7;
  color: rgba(253,250,244,0.6);
}

/* CONTACT */
.contact-section {
  padding: 5rem 4rem;
  background: var(--dark);
  text-align: center;
  border-top: 1px solid rgba(201,168,76,0.15);
}
.contact-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300;
  margin-bottom: 0.5rem;
}
.contact-title em { font-style: italic; color: var(--gold); }
.contact-links {
  display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;
  margin-top: 2.5rem;
}
.contact-link {
  display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  text-decoration: none; transition: transform 0.3s;
}
.contact-link:hover { transform: translateY(-4px); }
.contact-link-label {
  font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--gold);
}
.contact-link-val {
  font-size: 0.9rem; color: rgba(253,250,244,0.7);
}

footer {
  background: var(--dark-2); text-align: center;
  padding: 1.5rem;
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(253,250,244,0.25);
  border-top: 1px solid rgba(201,168,76,0.08);
}

/* SCROLL REVEAL */
.reveal {
  opacity: 0; transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.hero-text { animation: fadeIn 1s ease 0.3s both; }
.hero-image { animation: fadeIn 1s ease 0.6s both; }

/* RESPONSIVE */
@media (max-width: 900px) {
  nav { padding: 1rem 1.5rem; }
  .nav-links { display: none; }
  .hero { grid-template-columns: 1fr; padding: 6rem 1.5rem 3rem; text-align: center; }
  .hero::before { display: none; }
  .hero-eyebrow { justify-content: center; }
  .hero-desc { margin: 0 auto 2rem; }
  .hero-cta { justify-content: center; }
  .hero-image { display: none; }
  .vaga-section, .skills-section, .exp-section, .certs-section, .diff-section, .contact-section {
    padding: 4rem 1.5rem;
  }
  .fit-grid, .skills-grid, .diff-grid { grid-template-columns: 1fr; }
  .skills-grid { gap: 0; }
  .timeline::before { left: 0; }
  .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
  .exp-item::after { display: none; }
  .exp-date { text-align: left; }
  .exp-content { padding-left: 0; }
  .contact-links { flex-direction: column; align-items: center; }
}
</style>
</head>
